<Window x:Class="IbisTestTool.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="IBIS Test (IBIStools-Logik, .NET 8)"

        Height="720" Width="920"

        MinHeight="600" MinWidth="760">

    <Grid Margin="12">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="160"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <GroupBox Header="COM-Port" Padding="8" Margin="0,0,0,8">

            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

                    <ComboBox x:Name="PortCombo" Width="120" Margin="0,0,8,0" IsEditable="True"/>

                    <Button Content="Aktualisieren" Click="RefreshPorts_Click" Margin="0,0,8,0"/>

                    <Button Content="Port testen (Linie 300)" Click="TestPort_Click" Margin="0,0,8,0"/>

                    <Button Content="Diagnose alle Modi" Click="Diagnose_Click" Margin="0,0,8,0"/>

                </StackPanel>

                <ComboBox x:Name="LinkModeCombo" Width="520" HorizontalAlignment="Left" SelectedIndex="1">

                    <ComboBoxItem Content="IBIS-Wandler CH340 (7E2 nativ) – wie Android"/>

                    <ComboBoxItem Content="8N2 Even-Emulation (IBISui / Bluetooth)"/>

                    <ComboBoxItem Content="IVU-Klartext 8N1 (DS001;300 / DS009;Text)"/>

                </ComboBox>

            </StackPanel>

        </GroupBox>



        <GroupBox Grid.Row="1" Header="Telegramme (wie IBISui)" Padding="8" Margin="0,0,0,8">

            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

                    <CheckBox x:Name="LineCheck" Content="Linie" IsChecked="True" VerticalAlignment="Center" Width="60"/>

                    <TextBox x:Name="LineBox" Text="300" Width="80" Margin="4,0,16,0"/>

                    <ComboBox x:Name="LaTypeCombo" Width="100" SelectedIndex="0">

                        <ComboBoxItem Content="ds001"/>

                        <ComboBoxItem Content="ds001neu"/>

                    </ComboBox>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

                    <CheckBox x:Name="DestCheck" Content="Ziel" VerticalAlignment="Center" Width="60"/>

                    <TextBox x:Name="DestLine1" Width="200" Margin="4,0,8,0" ToolTip="Zeile 1 (16 Zeichen, zentriert)"/>

                    <TextBox x:Name="DestLine2" Width="200" ToolTip="Zeile 2"/>

                    <ComboBox x:Name="ZaTypeCombo" Width="120" Margin="8,0,0,0" SelectedIndex="0">

                        <ComboBoxItem Content="ds003a (zA2)"/>

                        <ComboBoxItem Content="ds3aMAS (zA4)"/>

                        <ComboBoxItem Content="ds3aMAS ctrl (zA5)"/>

                    </ComboBox>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

                    <CheckBox x:Name="StopCheck" Content="HSA" IsChecked="True" VerticalAlignment="Center" Width="60"/>

                    <TextBox x:Name="StopBox" Text="Test" Width="200" Margin="4,0,8,0"/>

                    <ComboBox x:Name="HsaTypeCombo" Width="90" SelectedIndex="0" SelectionChanged="HsaTypeCombo_SelectionChanged">

                        <ComboBoxItem Content="ds009"/>

                        <ComboBoxItem Content="ds003c"/>

                    </ComboBox>

                    <ComboBox x:Name="HsaLenCombo" Width="55" SelectedIndex="0" ToolTip="Textfeld-Länge (ds009/ds003c)">

                        <ComboBoxItem Content="16"/>

                        <ComboBoxItem Content="20"/>

                        <ComboBoxItem Content="24"/>

                        <ComboBoxItem Content="28"/>

                        <ComboBoxItem Content="32"/>

                        <ComboBoxItem Content="36"/>

                        <ComboBoxItem Content="40"/>

                        <ComboBoxItem Content="44"/>

                        <ComboBoxItem Content="48"/>

                    </ComboBox>

                    <ComboBox x:Name="HsaFormatCombo" Width="150" SelectedIndex="0" ToolTip="v0 = Matrix-Originalsoftware, v = IBISui">

                        <ComboBoxItem Content="v0 (Matrix)"/>

                        <ComboBoxItem Content="v IBISui"/>

                        <ComboBoxItem Content="v links (17)"/>

                    </ComboBox>

                    <TextBlock Text="×" VerticalAlignment="Center" Margin="4,0"/>

                    <ComboBox x:Name="HsaRepeatCombo" Width="45" SelectedIndex="2" ToolTip="Wiederholungen (Android: 3×)">

                        <ComboBoxItem Content="1"/>

                        <ComboBoxItem Content="2"/>

                        <ComboBoxItem Content="3"/>

                    </ComboBox>

                    <Button Content="Nur HSA" Click="TestHsa_Click" Margin="8,0,0,0" Padding="8,2"/>

                </StackPanel>

                <TextBlock Foreground="Gray" FontSize="11" Margin="60,0,0,4"

                           Text="Viele Matrix-Innenanzeigen: v0+16 Zeichen (nicht v wie IBISui). 3× wiederholen."/>

                <StackPanel Orientation="Horizontal">

                    <CheckBox x:Name="RawCheck" Content="RAW" VerticalAlignment="Center" Width="60"/>

                    <TextBox x:Name="RawBox" Width="500" Margin="4,0,0,0"

                             ToolTip="Roher IBIS-Befehl ohne CR/Parität"/>

                </StackPanel>

            </StackPanel>

        </GroupBox>



        <GroupBox Grid.Row="2" Header="Vorschau (Hex)" Padding="8" Margin="0,0,0,8">

            <TextBox x:Name="PreviewBox" IsReadOnly="True" TextWrapping="Wrap"

                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

        </GroupBox>



        <GroupBox Grid.Row="3" Header="Log" Padding="8" Margin="0,0,0,8">

            <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"

                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

        </GroupBox>



        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">

            <Button Content="Vorschau aktualisieren" Click="Preview_Click" Margin="0,0,8,0" Padding="12,6"/>

            <Button Content="Senden" Click="Send_Click" Padding="16,6" FontWeight="Bold"/>

        </StackPanel>

    </Grid>

</Window>


